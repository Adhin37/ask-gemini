{
  "name": "ask-gemini-extension",
  "version": "1.6.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:dev": "node build.mjs --dev",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:js": "eslint src/",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:html": "htmlhint \"src/**/*.html\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e:purge": "node -e \"require('fs').rmSync('e2e/videos', { recursive: true, force: true })\"",
    "e2e": "npm run e2e:purge && playwright test --config=e2e/playwright.config.js",
    "e2e:stitch": "node e2e/stitch.mjs",
    "e2e:demo": "npm run e2e && npm run e2e:stitch"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "htmlhint": "^1.1.4",
    "jsdom": "^29.0.1",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "vitest": "^3.0.0"
  }
}
