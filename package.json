{
  "name": "ask-gemini-extension",
  "version": "1.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "lint":      "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:js":   "eslint src/",
    "lint:css":  "stylelint \"src/**/*.css\"",
    "lint:html": "htmlhint \"src/**/*.html\""
  },
  "devDependencies": {
    "eslint":                 "^9.0.0",
    "globals":                "^15.0.0",
    "stylelint":              "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "htmlhint":               "^1.1.4"
  }
}
