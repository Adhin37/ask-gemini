{
  "manifest_version": 3,
  "name": "Ask Gemini",
  "version": "1.6.2",
  "description": "Instantly send questions to Google Gemini from your browser.",
  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://consent.google.com/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Ask Gemini (Ctrl+Shift+L)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "open_popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open Ask Gemini popup"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/background.min.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "src/content/content.min.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
